APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Canonical Encounter State — Shadow Mode toggle (see
# reports/encounter-state-machine-design/01-integration-and-migration-architecture.md).
# Defaults to false: disabled unless explicitly set true in a given environment.
CANONICAL_ENCOUNTER_SHADOW_MODE_ENABLED=false

# Encounter Workspace V2 rebuild toggle (see reports/clinical-notes-frontend-rebuild-plan.md).
# Defaults to false: the /encounters/{id}/v2 route 404s until explicitly enabled.
FRONTEND_WORKSPACE_V2_ENABLED=false

# Encounters list page toggle — a genuinely new page, no existing route to protect.
# Defaults to false: the /encounters route 404s until explicitly enabled.
FRONTEND_ENCOUNTERS_LIST_ENABLED=false

# Patient Chart V2 rebuild toggle (see reports/patient-chart-rebuild-plan.md).
# Defaults to false: the /patients/{id}/chart/v2 route 404s until explicitly enabled.
FRONTEND_PATIENT_CHART_V2_ENABLED=false

# Medical Records Index V2 rebuild toggle (see reports/medical-records-index-rebuild-plan.md).
# Defaults to false: the /medical-records/v2 route 404s until explicitly enabled.
FRONTEND_MEDICAL_RECORDS_INDEX_V2_ENABLED=false

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
# If serving this app over https (e.g. a Laravel Herd/Valet *.test domain),
# set REVERB_HOST to that exact domain and REVERB_SCHEME=https -- Reverb
# auto-detects the Herd/Valet-issued cert for that hostname
# (Laravel\Reverb\Certificate::resolve()) and terminates TLS itself, so the
# browser's wss:// connection is trusted with no extra setup. Leaving this as
# plain "localhost"/http while the app itself runs on https causes the
# browser to silently refuse the WebSocket (mixed content) -- the Patient
# Flow Board's "Live" badge will just show "Polling" forever if that happens.
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

AUDIT_EXPORT_JOB_RETENTION_DAYS=30
AUDIT_EXPORT_JOB_RETENTION_BATCH=500
AUDIT_EXPORT_JOB_FILE_DIRECTORY=audit-exports
AUDIT_EXPORT_JOB_RETENTION_SCHEDULE_ENABLED=false
AUDIT_EXPORT_JOB_RETENTION_SCHEDULE_CRON="41 2 * * *"
AUDIT_EXPORT_JOB_RETENTION_SCHEDULE_ALLOWED_ENVS=production

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
# Gmail SMTP on port 587 works with MAIL_SCHEME=smtp.
# MAIL_SCHEME=tls is accepted and normalized to smtp with required STARTTLS.
# MAIL_REQUIRE_TLS=true
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_REPLY_TO_ADDRESS=null
MAIL_REPLY_TO_NAME=null

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ======================================
# Billing Integrations (Tanzania-specific)
# ======================================
# Payment Gateway (Selcom)
SELCOM_BASE_URL=https://api.selcommobile.com
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_VENDOR=
SELCOM_PIN=
SELCOM_CURRENCY=TZS

# NHIF API
NHIF_API_BASE_URL=https://api.nhif.or.tz
NHIF_CLIENT_ID=
NHIF_CLIENT_SECRET=
NHIF_API_SCOPE=OMRS
NHIF_AUTO_VERIFY_ON_CHECKIN=true
NHIF_FACILITY_CODE=

# TRA/VFD (TotalVFD)
TOTALVFD_BASE_URL=https://testapi.totalvfd.co.tz
TOTALVFD_API_KEY=
TOTALVFD_API_SECRET=
TOTALVFD_TIN=
TOTALVFD_VRN=
TOTALVFD_BUSINESS_NAME=
TOTALVFD_BUSINESS_STREET=
TOTALVFD_BUSINESS_CITY=Dar Es Salaam
TOTALVFD_BUSINESS_MOBILE=
TOTALVFD_EFD_SERIAL=
TOTALVFD_TAX_OFFICE=

# SMS Provider (Africa's Talking)
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_FROM=
AFRICASTALKING_BASE_URL=https://api.africastalking.com
